---
import '@fontsource-variable/space-grotesk/wght.css';
import '@fontsource-variable/jetbrains-mono/wght.css';
import '../styles/global.css';
import { PERSON, SOCIAL_IMAGE, SOCIAL_IMAGE_WIDTH, SOCIAL_IMAGE_HEIGHT } from '../consts';
import {
    getAlternateLinks,
    LOCALE_TAGS,
    LANGS,
    type Lang
} from '../i18n/utils';

declare const __LAST_MODIFIED__: string;

export interface Props {
    title: string;
    description: string;
    lang: Lang;
    image?: string;
    ogType?: string;
}

const { title, description, lang, image = SOCIAL_IMAGE, ogType = 'website' } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
const alternates = getAlternateLinks(Astro.url.pathname, Astro.site);
const ogLocale = LOCALE_TAGS[lang];
const ogLocaleAlternate = LANGS.filter((l) => l !== lang).map(
    (l) => LOCALE_TAGS[l]
);

const personSchema = {
    '@context': 'https://schema.org',
    '@type': 'ProfilePage',
    dateModified: __LAST_MODIFIED__,
    url: canonicalURL.href,
    mainEntity: {
        '@id': `${Astro.site?.href}#person`,
        '@type': 'Person',
        name: PERSON.name,
        jobTitle: PERSON.jobTitle,
        url: Astro.site?.href,
        email: PERSON.email,
        image: imageURL.href,
        description: 'Software engineer with 4+ years building high-concurrency, event-driven systems. Specialises in Python, Django, hexagonal architecture, and domain-driven design.',
        knowsAbout: [
            'Python', 'Django', 'FastAPI', 'Kafka', 'RabbitMQ',
            'PostgreSQL', 'Redis', 'Hexagonal Architecture',
            'Domain-Driven Design', 'Event Sourcing', 'Docker'
        ],
        sameAs: [PERSON.linkedin, PERSON.github]
    }
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="dark" />
<meta name="theme-color" content="#04070a" />
<meta name="robots" content="index, follow" />
<meta name="author" content={PERSON.name} />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

<link rel="canonical" href={canonicalURL} />

{
    alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))
}

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={PERSON.name} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL.href} />
<meta property="og:image:width" content={String(SOCIAL_IMAGE_WIDTH)} />
<meta property="og:image:height" content={String(SOCIAL_IMAGE_HEIGHT)} />
<meta property="og:image:type" content="image/png" />
<meta property="og:locale" content={ogLocale} />
{
    ogLocaleAlternate.map((loc) => (
        <meta property="og:locale:alternate" content={loc} />
    ))
}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL.href} />
{PERSON.twitter && <meta name="twitter:site" content={`@${PERSON.twitter}`} />}
{PERSON.twitter && <meta name="twitter:creator" content={`@${PERSON.twitter}`} />}

{ogType !== 'article' && (
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
)}
