---
import { getContent, type Lang } from '../i18n/utils';

export interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const t = getContent(lang);
---

<section class="projects" data-reveal aria-labelledby="work-label">
    <h2 class="label" id="work-label">$ ls ./selected-work</h2>
    <div class="list">
        {
            t.projects.items.map((project) => (
                <a class="card" href={project.href}>
                    <div class="head">
                        <span class="name">{project.name}</span>
                        <span class="arrow" aria-hidden="true">
                            →
                        </span>
                    </div>
                    <p class="desc">{project.description}</p>
                    <div class="tags">{project.tags.join(' · ')}</div>
                </a>
            ))
        }
    </div>
</section>

<style>
    .projects {
        margin-bottom: 40px;
        animation: revealUp 0.6s ease 0.24s both;
    }
    .label {
        font-family: var(--font-mono);
        font-size: 0.875rem;
        font-weight: 400;
        color: var(--accent);
        letter-spacing: 0.06em;
        margin-bottom: 18px;
        text-shadow: 0 0 6px rgba(63, 224, 143, 0.3);
    }
    .list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .card {
        display: block;
        padding: 18px;
        border-radius: var(--radius);
        background: var(--surface-item);
        border: 1px solid var(--border-item);
        text-decoration: none;
        transition: border-color 0.2s ease, background 0.2s ease;
    }
    .card:hover {
        border-color: var(--border-item-hover);
        background: var(--surface-item-hover);
    }
    .head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 7px;
    }
    .name {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--heading-strong);
    }
    .arrow {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--accent);
    }
    .desc {
        font-size: 0.875rem;
        line-height: 1.55;
        color: var(--text-muted);
        margin-bottom: 11px;
    }
    .tags {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--mono-muted);
    }
</style>
