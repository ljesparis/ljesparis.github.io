---
import { PERSON } from '../consts';
import {
    getLangFromUrl,
    getContent,
    getLocalizedPath,
    LOCALE_TAGS
} from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = getContent(lang);
const otherLang = lang === 'en' ? 'es' : 'en';
const switchPath = getLocalizedPath(Astro.url.pathname, otherLang);
---

<nav class="nav" data-reveal aria-label="Primary">
    <span class="prompt">root@ljesparis:~$</span>
    <div class="nav-right">
        <a
            class="icon"
            href={PERSON.linkedin}
            target="_blank"
            rel="noopener noreferrer me"
            aria-label="LinkedIn"
        >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.63-1.85 3.36-1.85 3.59 0 4.25 2.36 4.25 5.43v6.31zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"></path>
            </svg>
        </a>
        <a
            class="icon"
            href={PERSON.github}
            target="_blank"
            rel="noopener noreferrer me"
            aria-label="GitHub"
        >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2 0-.4-.5-1.6.2-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.7 1.6.2 2.8.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3z"></path>
            </svg>
        </a>
        <a
            class="lang"
            href={switchPath}
            lang={otherLang}
            hreflang={LOCALE_TAGS[otherLang]}
            aria-label={`Switch language to ${t.switchToLabel}`}
        >
            {lang.toUpperCase()}
        </a>
    </div>
</nav>

<style>
    .nav {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        padding: 11px 13px 11px 17px;
        margin-bottom: 44px;
        border-radius: var(--radius);
        background: var(--surface-nav);
        border: 1px solid var(--border);
        backdrop-filter: blur(10px);
        position: sticky;
        top: 14px;
        z-index: 20;
        animation: revealUp 0.6s ease both;
    }
    .prompt {
        font-family: var(--font-mono);
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--accent-bright);
        text-shadow: 0 0 8px rgba(63, 224, 143, 0.5);
    }
    .nav-right {
        display: flex;
        align-items: center;
        gap: 14px;
    }
    .icon {
        display: flex;
        padding: 7px;
        margin: -7px;
        color: var(--accent);
        transition: color 0.2s ease;
    }
    .icon:hover {
        color: var(--accent-bright);
    }
    .lang {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--on-accent);
        background: var(--accent);
        padding: 6px 11px;
        border-radius: var(--radius-sm);
        text-decoration: none;
        transition: background 0.2s ease;
    }
    .lang:hover {
        background: var(--accent-bright);
    }
</style>
