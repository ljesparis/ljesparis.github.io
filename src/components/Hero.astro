---
import { PERSON } from '../consts';
import { getLangFromUrl, getContent, type Lang } from '../i18n/utils';

export interface Props {
    lang: Lang;
}

const { lang } = Astro.props;
const t = getContent(lang);
const [firstName, ...rest] = PERSON.name.split(' ');
const lastName = rest.join(' ');
---

<header class="hero" data-reveal>
    <p class="whoami">
        $ whoami<span class="cursor" aria-hidden="true"></span>
    </p>
    <h1 class="name">{firstName}<br />{lastName}</h1>
    <p class="role">{PERSON.jobTitle}</p>
    <p class="tagline">&gt; {t.hero.tagline}</p>
</header>

<style>
    .hero {
        margin-bottom: 40px;
        animation: revealUp 0.6s ease 0.08s both;
    }
    .whoami {
        display: flex;
        align-items: center;
        font-family: var(--font-mono);
        font-size: 0.8125rem;
        color: var(--accent);
        letter-spacing: 0.05em;
        margin-bottom: 20px;
        text-shadow: 0 0 6px rgba(63, 224, 143, 0.4);
    }
    .cursor {
        display: inline-block;
        width: 9px;
        height: 17px;
        margin-left: 7px;
        transform: translateY(2px);
        background: var(--accent);
        box-shadow: 0 0 8px var(--accent);
        animation: blink 1.1s step-end infinite;
    }
    .name {
        font-family: var(--font-mono);
        font-size: clamp(2.75rem, 7vw + 1rem, 3.25rem);
        line-height: 1.02;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--heading);
        text-shadow: 0 0 20px rgba(63, 224, 143, 0.35);
        margin-bottom: 18px;
    }
    .role {
        font-family: var(--font-mono);
        font-size: 0.9375rem;
        font-weight: 500;
        color: var(--accent-bright);
        letter-spacing: 0.03em;
        margin-bottom: 10px;
    }
    .tagline {
        font-family: var(--font-mono);
        font-size: 0.875rem;
        color: var(--text-muted);
        letter-spacing: 0.01em;
    }
</style>
